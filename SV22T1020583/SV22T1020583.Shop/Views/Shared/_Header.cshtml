@using Microsoft.AspNetCore.Http
@using Newtonsoft.Json
@inject IHttpContextAccessor HttpContextAccessor
@{
    // Logic tính số lượng sản phẩm trong giỏ hàng để hiển thị lên Badge
    int cartCount = 0;
    var sessionData = HttpContextAccessor.HttpContext?.Session.GetString("MyCart");
    if (!string.IsNullOrEmpty(sessionData))
    {
        var cart = JsonConvert.DeserializeObject<List<SV22T1020583.Shop.Models.CartItem>>(sessionData);
        cartCount = cart?.Count ?? 0;
    }
}

<header class="sticky-top shadow-sm">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary py-2">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center" href="~/">
                <i class="bi bi-lightning-charge-fill me-2"></i> DY SHOP
            </a>

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <form class="d-flex mx-lg-auto mb-2 mb-lg-0 w-100" style="max-width: 500px;" action="~/Home/Index" method="get">
                    <div class="input-group">
                        <input class="form-control border-0 rounded-start-pill ps-4"
                               type="search" name="searchValue"
                               placeholder="Bạn tìm gì hôm nay?"
                               value="@ViewBag.SearchValue">
                        <button class="btn btn-light text-primary rounded-end-pill px-3" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <ul class="navbar-nav ms-lg-4 align-items-center">
                    <li class="nav-item me-3">
                        <a class="nav-link position-relative p-1" href="~/Cart">
                            <i class="bi bi-cart3 fs-4 text-white"></i>
                            @if (cartCount > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light"
                                      style="font-size: 0.65rem; padding: 0.35em 0.5em;">
                                    @cartCount
                                </span>
                            }
                        </a>
                    </li>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center bg-white bg-opacity-10 rounded-pill px-3"
                               href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-2"></i>
                                <span>@User.Identity.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-2">
                                <li><a class="dropdown-item" href="~/Account/Profile"><i class="bi bi-person me-2"></i> Hồ sơ</a></li>
                                <li><a class="dropdown-item" href="~/Order/History"><i class="bi bi-bag-check me-2"></i> Đơn hàng</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="~/Account/Logout"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link fw-bold px-3" href="~/Account/Login">Đăng nhập</a>
                        </li>
                        <li class="nav-item ms-lg-2">
                            <a class="btn btn-light text-primary fw-bold rounded-pill px-4 shadow-sm" href="~/Account/Register">Đăng ký</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>

<style>
    .navbar-dark .nav-link {
        color: rgba(255,255,255,0.9);
        transition: 0.3s;
    }

        .navbar-dark .nav-link:hover {
            color: #fff;
        }

    .dropdown-item {
        padding: 0.6rem 1.5rem;
        transition: 0.2s;
    }

        .dropdown-item:hover {
            background-color: #f8f9fa;
            color: #0d6efd;
        }

    .input-group .form-control:focus {
        box-shadow: none;
        border: none;
    }
</style>