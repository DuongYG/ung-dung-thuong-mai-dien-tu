@{
    // Lấy các giá trị hiện tại từ ViewBag để duy trì bộ lọc
    int currentCatID = ViewBag.CategoryID ?? 0;
    string currentSearch = ViewBag.SearchValue ?? "";
    decimal currentMinPrice = ViewBag.MinPrice ?? 0;
    decimal currentMaxPrice = ViewBag.MaxPrice ?? 0;
}

<div class="card border-0 shadow-sm mb-4 rounded-3 overflow-hidden">
    <div class="card-header bg-primary text-white fw-bold py-3">
        <i class="bi bi-list-ul me-2"></i> DANH MỤC HÀNG
    </div>
    <div class="list-group list-group-flush">
        <a href="~/Home/Index?categoryID=0&searchValue=@currentSearch"
           class="list-group-item list-group-item-action border-0 d-flex justify-content-between align-items-center @(currentCatID == 0 ? "active bg-light text-primary fw-bold" : "")">
            <span>Tất cả sản phẩm</span>
            @if (currentCatID == 0)
            {
                <i class="bi bi-check2"></i>
            }
        </a>

        @if (ViewBag.Categories != null)
        {
            foreach (var cat in ViewBag.Categories)
            {
                <a href="~/Home/Index?categoryID=@cat.CategoryID&searchValue=@currentSearch"
                   class="list-group-item list-group-item-action border-0 d-flex justify-content-between align-items-center @(currentCatID == cat.CategoryID ? "active bg-light text-primary fw-bold" : "")">
                    <span>@cat.CategoryName</span>
                    @if (currentCatID == cat.CategoryID)
                    {
                        <i class="bi bi-check2"></i>
                    }
                </a>
            }
        }
    </div>
</div>

<div class="card border-0 shadow-sm rounded-3 overflow-hidden">
    <div class="card-header bg-white fw-bold py-3 border-bottom">
        <i class="text-primary me-2"></i> KHOẢNG GIÁ
    </div>
    <div class="list-group list-group-flush">
        @* Link: Dưới 1 triệu *@
        <a href="~/Home/Index?minPrice=0&maxPrice=1000000&categoryID=@currentCatID&searchValue=@currentSearch"
           class="list-group-item list-group-item-action border-0 @(currentMaxPrice == 1000000 ? "text-primary fw-bold" : "")">
            <i class="bi bi-chevron-right small me-1"></i> Dưới 1.000.000đ
        </a>

        @* Link: 1 triệu - 5 triệu *@
        <a href="~/Home/Index?minPrice=1000000&maxPrice=5000000&categoryID=@currentCatID&searchValue=@currentSearch"
           class="list-group-item list-group-item-action border-0 @(currentMinPrice == 1000000 && currentMaxPrice == 5000000 ? "text-primary fw-bold" : "")">
            <i class="bi bi-chevron-right small me-1"></i> 1.000.000đ - 5.000.000đ
        </a>

        @* Link: Trên 5 triệu *@
        <a href="~/Home/Index?minPrice=5000000&maxPrice=0&categoryID=@currentCatID&searchValue=@currentSearch"
           class="list-group-item list-group-item-action border-0 @(currentMinPrice == 5000000 ? "text-primary fw-bold" : "")">
            <i class="bi bi-chevron-right small me-1"></i> Trên 5.000.000đ
        </a>

        @* Nút xóa lọc giá nhanh *@
        @if (currentMaxPrice > 0 || currentMinPrice > 0)
        {
            <a href="~/Home/Index?minPrice=0&maxPrice=0&categoryID=@currentCatID&searchValue=@currentSearch"
               class="list-group-item list-group-item-action border-0 text-center text-muted small py-2 bg-light">
                <i class="bi bi-x-circle me-1"></i> Bỏ lọc giá
            </a>
        }
    </div>
</div>

<style>
    /* Hiệu ứng hover cho các item trong sidebar */
    .list-group-item-action {
        transition: all 0.2s ease;
        font-size: 0.95rem;
    }

        .list-group-item-action:hover {
            background-color: #f8f9fa;
            padding-left: 1.25rem;
            color: #0d6efd;
        }

    .list-group-item.active {
        z-index: 2;
        color: #0d6efd !important;
        background-color: #f0f7ff !important;
        border-left: 4px solid #0d6efd !important;
    }
</style>