@model SV22T1020583.Models.Common.PagedResult<SV22T1020583.Models.Catalog.Product>
@{
    ViewData["Title"] = "Mua sắm";
    string searchValue = ViewBag.SearchValue ?? "";
    int categoryID = ViewBag.CategoryID ?? 0;
    decimal minPrice = ViewBag.MinPrice ?? 0;
    decimal maxPrice = ViewBag.MaxPrice ?? 0;
}

<div class="container">
    @* Thanh trạng thái hiển thị bộ lọc đang áp dụng *@
    @if (!string.IsNullOrEmpty(searchValue) || categoryID > 0 || maxPrice > 0)
    {
        <div class="alert alert-white shadow-sm border-0 mb-4 d-flex justify-content-between align-items-center bg-white rounded-3">
            <div class="small">
                <i class="bi bi-funnel text-primary me-2"></i>
                @if (categoryID > 0)
                {
                    <span class="badge bg-light text-dark border me-1">Danh mục: @categoryID</span>
                }
                @if (!string.IsNullOrEmpty(searchValue))
                {
                    <span class="badge bg-light text-dark border me-1">Từ khóa: @searchValue</span>
                }
                @if (maxPrice > 0)
                {
                    <span class="badge bg-primary">Giá: @minPrice.ToString("N0") - @maxPrice.ToString("N0")</span>
                }
            </div>
            <a href="~/" class="btn btn-sm text-muted text-decoration-none small">Thiết lập lại</a>
        </div>
    }

    @* Lưới sản phẩm (Chiếm toàn bộ chiều rộng vì Sidebar đã ở trên Header) *@
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var p in Model.DataItems)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 product-card">
                    <a href="~/Product/Detail/@p.ProductID" class="p-3 text-center">
                        <img src="~/images/products/@(string.IsNullOrEmpty(p.Photo) ? "no-image.png" : p.Photo)"
                             class="card-img-top" style="height:180px; object-fit:contain;">
                    </a>
                    <div class="card-body text-center pt-0">
                        <h6 class="fw-bold text-truncate">@p.ProductName</h6>
                        <p class="text-danger fw-bold">@p.Price.ToString("N0") đ</p>
                        <a href="~/Product/Detail/@p.ProductID" class="btn btn-primary btn-sm rounded-pill w-100 shadow-sm">Xem chi tiết</a>
                    </div>
                </div>
            </div>
        }
    </div>

    @* Phân trang giữ lại các tham số lọc *@
    @if (Model.PageCount > 1)
    {
        <nav class="mt-5 mb-5">
            <ul class="pagination justify-content-center border-0 flex-wrap">
                @for (int i = 1; i <= Model.PageCount; i++)
                {
                    if (i == 1 || i == Model.PageCount || (i >= Model.Page - 2 && i <= Model.Page + 2))
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "") mx-1">
                            <a class="page-link shadow-sm border-0 rounded-circle"
                               href="~/Home/Index?page=@i&categoryID=@categoryID&searchValue=@searchValue&minPrice=@minPrice&maxPrice=@maxPrice"
                               style="width:38px; height:38px; display:flex; align-items:center; justify-content:center;">@i</a>
                        </li>
                    }
                    else if (i == Model.Page - 3 || i == Model.Page + 3)
                    {
                        <li class="page-item disabled mx-1"><span class="page-link border-0 bg-transparent">...</span></li>
                    }
                }
            </ul>
        </nav>
    }
</div>