@model SV22T1020583.Models.Partner.Customer
@{
    Layout = "_Layout";
    ViewBag.Title = "Đăng ký tài khoản khách hàng";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-3">
                        <h2 class="fw-bold">Tạo tài khoản mới</h2>
                        <p class="text-muted">Đăng ký để trải nghiệm mua sắm tuyệt vời tại DY SHOP</p>
                    </div>

                    <form asp-action="Register" method="post">
                        @Html.AntiForgeryToken()

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Tên khách hàng</label>
                                <input type="text" asp-for="CustomerName" class="form-control" placeholder="VD: Nguyễn Văn A" required />
                                <span asp-validation-for="CustomerName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Tên liên hệ</label>
                                <input type="text" asp-for="ContactName" class="form-control" placeholder="Tên thường gọi" required />
                                <span asp-validation-for="ContactName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email (Tài khoản đăng nhập)</label>
                            <input type="email" asp-for="Email" class="form-control" placeholder="email@example.com" required />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Mật khẩu</label>
                                <input type="password" asp-for="Password" class="form-control" placeholder="Tối thiểu 6 ký tự" required />
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Xác nhận mật khẩu</label>
                                <input type="password" name="confirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Số điện thoại</label>
                            <input type="tel" asp-for="Phone" class="form-control" placeholder="Số điện thoại của bạn" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Tỉnh/Thành phố</label>
                            <select asp-for="Province" class="form-select select2">
                                <option value="">-- Chọn Tỉnh/Thành phố --</option>
                                @foreach (var p in ViewBag.Provinces)
                                {
                                    <option value="@p.ProvinceName">@p.ProvinceName</option>
                                }
                            </select>
                            <span asp-validation-for="Province" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Địa chỉ chi tiết</label>
                            <input type="text" asp-for="Address" class="form-control" placeholder="Số nhà, tên đường..." />
                        </div>

                        <div class="mb-3">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small shadow-sm"></div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold shadow-sm">
                            <i class="bi bi-person-plus-fill me-2"></i> ĐĂNG KÝ NGAY
                        </button>

                        <div class="text-center mt-4">
                            <span class="text-muted">Bạn đã có tài khoản?</span>
                            <a asp-action="Login" class="text-decoration-none fw-bold ms-1">Đăng nhập</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}