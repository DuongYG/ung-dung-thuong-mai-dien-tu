@model SV22T1020583.Models.Partner.Supplier
@{
    ViewBag.Title = Model.SupplierID > 0 ? "Cập nhật nhà cung cấp" : "Bổ sung nhà cung cấp";
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu dữ liệu
    </button>
    <a href="~/Supplier" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-truck me-2"></i> Thông tin nhà cung cấp
                </h5>
            </div>

            <div class="card-body">
                @* Đảm bảo action trỏ đúng về hàm Save của SupplierController *@
                <form id="formEdit" action="~/Supplier/SaveData" method="post">

                    @* 1. GIẢI PHÁP SỬA LỖI TẠO MỚI: Phải có ID ẩn ở đây *@
                    <input type="hidden" name="@nameof(Model.SupplierID)" value="@Model.SupplierID" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tên nhà cung cấp</label>
                            <input type="text" class="form-control" name="@nameof(Model.SupplierName)"
                                   value="@Model.SupplierName" placeholder="Nhập tên nhà cung cấp" autofocus />
                            @Html.ValidationMessage(nameof(Model.SupplierName), "", new { @class = "text-danger" })
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tên giao dịch</label>
                            <input type="text" class="form-control" name="@nameof(Model.ContactName)"
                                   value="@Model.ContactName" placeholder="Tên người liên hệ" />
                            @Html.ValidationMessage(nameof(Model.ContactName), "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Điện thoại</label>
                            <input type="tel" class="form-control" name="@nameof(Model.Phone)"
                                   value="@Model.Phone" placeholder="Số điện thoại" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Email</label>
                            <input type="email" class="form-control" name="@nameof(Model.Email)"
                                   value="@Model.Email" placeholder="Địa chỉ email" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Địa chỉ</label>
                        <input type="text" class="form-control" name="@nameof(Model.Address)"
                               value="@Model.Address" placeholder="Số nhà, tên đường..." />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Tỉnh / Thành</label>
                        <select class="form-select" name="@nameof(Model.Province)">
                            <option value="">-- Chọn Tỉnh/Thành --</option>
                            @* Sử dụng DictionaryDataService để lấy danh sách tỉnh thành *@
                            @foreach (var p in await SV22T1020583.BusinessLayers.DictionaryDataService.ListProvincesAsync())
                            {
                                if (p.ProvinceName == Model.Province)
                                {
                                    <option value="@p.ProvinceName" selected>@p.ProvinceName</option>
                                }
                                else
                                {
                                    <option value="@p.ProvinceName">@p.ProvinceName</option>
                                }
                            }
                        </select>
                        @Html.ValidationMessage(nameof(Model.Province), "", new { @class = "text-danger" })
                    </div>

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey("Error"))
                    {
                        <div class="alert alert-danger mt-3">
                            @Html.ValidationMessage("Error")
                        </div>
                    }
                </form>
            </div>
        </div>
    </div>
</div>