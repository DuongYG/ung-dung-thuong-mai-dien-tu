@model SV22T1020583.Models.Catalog.ProductAttribute
@{
    ViewBag.Title = Model.AttributeID == 0 ? "Bổ sung thuộc tính" : "Thay đổi thuộc tính";
}
@section PageToolBar {
    <button type="submit" form="formAttribute" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu thuộc tính
    </button>
    <a href="~/Product/Edit/@Model.ProductID" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card card-success card-outline">
            <div class="card-body">
                <form id="formAttribute" action="~/Product/SaveAttribute" method="post">
                    <input type="hidden" name="@nameof(Model.AttributeID)" value="@Model.AttributeID" />
                    <input type="hidden" name="@nameof(Model.ProductID)" value="@Model.ProductID" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên thuộc tính</label>
                        <input type="text" name="@nameof(Model.AttributeName)" value="@Model.AttributeName"
                               class="form-control" placeholder="Ví dụ: Màu sắc, Kích thước..." autofocus />
                        @Html.ValidationMessageFor(m => m.AttributeName, "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Giá trị</label>
                        <input type="text" name="@nameof(Model.AttributeValue)" value="@Model.AttributeValue"
                               class="form-control" placeholder="Ví dụ: Đỏ, Xanh, XL..." />
                        @Html.ValidationMessageFor(m => m.AttributeValue, "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Thứ tự hiển thị</label>
                        <input type="number" name="@nameof(Model.DisplayOrder)" value="@Model.DisplayOrder"
                               class="form-control" min="1" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>