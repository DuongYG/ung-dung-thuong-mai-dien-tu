@{
    ViewBag.Title = "Quản lý thuộc tính của ####";
}

<div class="container mt-4">

    <!-- ===== SEARCH AREA ===== -->
    <div class="card mb-3">
        <div class="card-body">
            <form class="row g-2 align-items-center">

                <div class="col-md-4">
                    <input type="text"
                           class="form-control"
                           placeholder="Nhập tên thuộc tính cần tìm">
                </div>

                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">
                        Search
                    </button>
                </div>

                <div class="col-auto">
                    <a href="/Product/AddAttribute"
                       class="btn btn-success">
                        + Add
                    </a>
                </div>

            </form>
        </div>
    </div>

    <!-- ===== RESULT COUNT ===== -->
    <div class="mb-2">
        <strong>Tìm thấy:</strong> 18 thuộc tính
    </div>

    <!-- ===== TABLE ===== -->
    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">

            <thead class="table-light">
                <tr>
                    <th>Tên thuộc tính</th>
                    <th>Chỉ số</th>
                    <th class="text-center" style="width:140px;">
                        Thứ tự hiển thị
                    </th>
                    <th class="text-center" style="width:130px;">
                        Thao tác
                    </th>
                </tr>
            </thead>

            <tbody>
                <!-- MOCK DATA -->
                <tr>
                    <td>Màu sắc</td>
                    <td>Đỏ</td>
                    <td class="text-center">1</td>
                    <td class="text-center">
                        <a href="/Product/EditAttribute/?1&attributeId=1"
                           class="btn btn-sm btn-warning">
                            Edit
                        </a>

                        <a href="/Product/DeleteAttribute/?1&attributeId=1"
                           class="btn btn-sm btn-danger">
                            Delete
                        </a>
                    </td>
                </tr>

                <tr>
                    <td>Dung lượng</td>
                    <td>512GB</td>
                    <td class="text-center">2</td>
                    <td class="text-center">
                        <a href="/Product/EditAttribute/?1&attributeId=2"
                           class="btn btn-sm btn-warning">
                            Edit
                        </a>

                        <a href="/Product/DeleteAttribute/Delete?1&attributeId=2"
                           class="btn btn-sm btn-danger">
                            Delete
                        </a>
                    </td>
                </tr>

                <!-- thêm mock rows nếu cần -->
            </tbody>

        </table>
    </div>

    <!-- ===== PAGINATION ===== -->
    <nav class="mt-3">
        <ul class="pagination justify-content-center">

            <li class="page-item disabled">
                <a class="page-link">Previous</a>
            </li>

            <li class="page-item active">
                <a class="page-link">1</a>
            </li>
            <li class="page-item">
                <a class="page-link">2</a>
            </li>
            <li class="page-item">
                <a class="page-link">3</a>
            </li>

            <li class="page-item disabled">
                <a class="page-link">...</a>
            </li>

            <li class="page-item">
                <a class="page-link">100</a>
            </li>

            <li class="page-item">
                <a class="page-link">Next</a>
            </li>

        </ul>
    </nav>

</div>
