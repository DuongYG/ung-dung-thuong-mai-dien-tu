@model SV22T1020583.Models.Catalog.Product
@using SV22T1020583.BusinessLayers
@using SV22T1020583.Models.Common
@{
    ViewBag.Title = Model.ProductID > 0 ? "Cập nhật mặt hàng" : "Bổ sung mặt hàng";
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i>
                    Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" action="~/Product/Save" method="post" enctype="multipart/form-data">
                    @* Lưu ID ẩn để thực hiện Update *@
                    <input type="hidden" name="ProductID" value="@Model.ProductID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tên mặt hàng</label>
                        <div class="col-sm-9">
                            <input type="text"
                                   class="form-control"
                                   name="ProductName"
                                   value="@Model.ProductName"
                                   placeholder="Nhập tên mặt hàng" autofocus />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Loại hàng</label>
                        <div class="col-sm-9">
                            <select class="form-select" name="CategoryID">
                                <option value="0">-- Chọn loại hàng --</option>
                                @{
                                    var catInput = new PaginationSearchInput() { Page = 1, PageSize = 0, SearchValue = "" };
                                    var categoryResult = await CatalogDataService.ListCategoriesAsync(catInput);
                                    foreach (var c in categoryResult.DataItems)
                                    {
                                        <option value="@c.CategoryID" selected="@(c.CategoryID == Model.CategoryID)">@c.CategoryName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Nhà cung cấp</label>
                        <div class="col-sm-9">
                            <select class="form-select" name="SupplierID">
                                <option value="0">-- Chọn nhà cung cấp --</option>
                                @{
                                    var supInput = new PaginationSearchInput() { Page = 1, PageSize = 0, SearchValue = "" };
                                    var supplierResult = await PartnerDataService.ListSuppliersAsync(supInput);
                                    foreach (var s in supplierResult.DataItems)
                                    {
                                        <option value="@s.SupplierID" selected="@(s.SupplierID == Model.SupplierID)">@s.SupplierName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Đơn vị tính</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="Unit" value="@Model.Unit" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Giá hàng</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control money-input" name="Price" value="@Model.Price.ToString("N0")" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-9 offset-sm-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="IsSelling" value="true" @(Model.IsSelling ? "checked" : "") />
                                <label class="form-check-label">Mặt hàng đang được bán</label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh</label>
                        <div class="col-sm-9">
                            <input type="file" class="form-control" name="uploadPhoto"
                                   accept="image/*" onchange="document.getElementById('imgPreview').src = window.URL.createObjectURL(this.files[0])" />
                            <input type="hidden" name="Photo" value="@Model.Photo" />
                            <div class="mt-2">
                                <img id="imgPreview"
                                     src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                     class="img-thumbnail" style="max-height: 160px;" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Mô tả</label>
                        <div class="col-sm-9">
                            <textarea class="form-control" name="ProductDescription" rows="3">@Model.ProductDescription</textarea>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@if (Model.ProductID > 0)
{
    await Html.RenderPartialAsync("ListPhotos", Model.ProductID);
    await Html.RenderPartialAsync("ListAttributes", Model.ProductID);
}