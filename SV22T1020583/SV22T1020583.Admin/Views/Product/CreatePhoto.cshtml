@model SV22T1020583.Models.Catalog.ProductPhoto
@{
    ViewBag.Title = "Bổ sung ảnh cho mặt hàng";
}
<div class="card card-primary card-outline">
    <div class="card-body">
        <form action="~/Product/SavePhoto" method="post" enctype="multipart/form-data">
            <input type="hidden" name="ProductID" value="@Model.ProductID" />
            <input type="hidden" name="PhotoID" value="0" />

            <div class="mb-3">
                <label class="form-label fw-bold">Chọn file ảnh</label>
                <input type="file" class="form-control" name="uploadPhoto" accept="image/*"
                       onchange="document.getElementById('imgPrev').src = window.URL.createObjectURL(this.files[0])" />
            </div>
            <div class="mb-3 text-center">
                <img id="imgPrev" src="~/images/products/nophoto.png"
                     class="img-thumbnail" style="max-height:200px" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Mô tả ảnh</label>
                <input type="text" name="Description" class="form-control" placeholder="Nhập mô tả ngắn gọn..." />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Thứ tự hiển thị</label>
                <input type="number" name="DisplayOrder" class="form-control" value="1" min="1" />
            </div>
            <div class="text-end">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Lưu dữ liệu</button>
                <a href="~/Product/Edit/@Model.ProductID" class="btn btn-secondary">Hủy bỏ</a>
            </div>
        </form>
    </div>
</div>