@model IEnumerable<SV22T1020583.Models.Catalog.ProductPhoto>
@{
    Layout = null;
}

<div class="card card-info card-outline mt-4">
    <div class="card-header">
        <div class="row">
            <div class="col"><h6 class="mb-0"><i class="bi bi-images me-2"></i>Thư viện ảnh</h6></div>
            <div class="col text-end">
                @* Link tới trang CreatePhoto *@
                <a class="btn btn-sm btn-primary" href="~/Product/CreatePhoto/@ViewBag.ProductID">
                    <i class="bi bi-plus-circle me-1"></i> Thêm ảnh
                </a>
            </div>
        </div>
    </div>

    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th style="width:120px">Ảnh</th>
                    <th>Mô tả / Thứ tự</th>
                    <th style="width:100px" class="text-center">Trạng thái</th>
                    <th style="width:100px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center">
                            <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "demo.png" : item.Photo)"
                                 class="img-thumbnail" style="max-height:80px;" />
                        </td>
                        <td>
                            <div class="fw-bold">@item.Description</div>
                            <small class="text-muted">Thứ tự ưu tiên: @item.DisplayOrder</small>
                        </td>

                        <td class="text-center">
                            @if (item.IsHidden)
                            {
                                <span class="badge bg-danger">Ẩn</span>
                            }
                            else
                            {

                                <span class="badge bg-success">Hiện</span>
                            }
                        </td>
                        <td class="text-center">
                            <a class="btn btn-sm btn-primary" href="~/Product/EditPhoto/@item.ProductID?photoId=@item.PhotoID">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a class="btn btn-sm btn-danger" href="~/Product/DeletePhoto/@item.ProductID?photoId=@item.PhotoID">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>