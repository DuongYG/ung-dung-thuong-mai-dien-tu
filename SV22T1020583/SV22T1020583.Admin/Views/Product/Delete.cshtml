@model SV22T1020583.Models.Catalog.Product
@using SV22T1020583.BusinessLayers
@{
    ViewBag.Title = "Xóa mặt hàng";
}

@section PageToolBar {
    <form action="~/Product/DeleteConfirm/@Model.ProductID" method="post">
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>
            Xác nhận xóa
        </button>
        <a href="~/Product" class="btn btn-secondary ms-1">
            <i class="bi bi-arrow-left"></i>
            Quay lại
        </a>
    </form>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-danger card-outline shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger font-weight-bold">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Xác nhận xóa mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <div class="alert alert-warning d-flex align-items-center mb-4">
                    <i class="bi bi-info-circle-fill me-3 fs-4"></i>
                    <div>
                        Bạn có chắc chắn muốn xóa mặt hàng sau không? <br />
                        <strong class="text-dark">Hành động này không thể hoàn tác và sẽ xóa toàn bộ dữ liệu liên quan.</strong>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-8">
                        <dl class="row mt-2">
                            <dt class="col-sm-4 text-muted">Tên mặt hàng:</dt>
                            <dd class="col-sm-8 text-primary fs-5"><strong>@Model.ProductName</strong></dd>

                            <dt class="col-sm-4 text-muted">Loại hàng:</dt>
                            <dd class="col-sm-8">
                                @* Dùng ?? 0 để chuyển int? sang int an toàn *@
                                @{
                                    var category = await CatalogDataService.GetCategoryAsync(Model.CategoryID ?? 0);
                                    @(category?.CategoryName ?? "N/A")
                                }
                            </dd>

                            <dt class="col-sm-4 text-muted">Nhà cung cấp:</dt>
                            <dd class="col-sm-8">
                                @* Dùng ?? 0 để chuyển int? sang int an toàn *@
                                @{
                                    var supplier = await PartnerDataService.GetSupplierAsync(Model.SupplierID ?? 0);
                                    @(supplier?.SupplierName ?? "N/A")
                                }
                            </dd>

                            <dt class="col-sm-4 text-muted">Đơn vị tính:</dt>
                            <dd class="col-sm-8">@Model.Unit</dd>

                            <dt class="col-sm-4 text-muted">Giá bán:</dt>
                            <dd class="col-sm-8 text-danger fw-bold">@Model.Price.ToString("N0") VNĐ </dd>

                            <dt class="col-sm-4 text-muted">Trạng thái:</dt>
                            <dd class="col-sm-8">
                                @if (Model.IsSelling)
                                {
                                    <span class="badge bg-success">Đang kinh doanh</span>
                                                                }
                                else
                                {
                                    <span class="badge bg-secondary">Ngừng bán</span>
                                                                }
                            </dd>

                            <dt class="col-sm-4 text-muted">Mô tả:</dt>
                            <dd class="col-sm-8">
                                <p class="text-muted small italic">
                                    @(string.IsNullOrEmpty(Model.ProductDescription) ? "(Không có mô tả)" : Model.ProductDescription) 
                                </p>
                            </dd>
                        </dl>
                    </div>

                    <div class="col-md-4 text-center border-start">
                        <label class="d-block mb-3 text-muted small text-uppercase fw-bold">Ảnh mặt hàng</label>
                        <img src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                             class="img-fluid img-thumbnail shadow-sm"
                             alt="Ảnh mặt hàng"
                             style="max-height: 250px; object-fit: contain;" /> 
                    </div>
                </div>
            </div>

            <div class="card-footer bg-light text-end">
                <span class="text-muted small italic">Mã hệ thống: #@Model.ProductID</span> 
            </div>
        </div>
    </div>
</div>