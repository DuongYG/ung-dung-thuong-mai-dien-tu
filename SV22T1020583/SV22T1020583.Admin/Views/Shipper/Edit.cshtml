@model SV22T1020583.Models.Partner.Shipper
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu dữ liệu
    </button>
    <a href="~/Shipper" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-bicycle me-2"></i> Thông tin người giao hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" action="~/Shipper/Save" method="post">
                    @* Summary: Mã người giao hàng dùng để định danh khi Save *@
                    <input type="hidden" name="@nameof(Model.ShipperID)" value="@Model.ShipperID" />

                    <div class="mb-3">
                        <label class="form-label">Tên người giao hàng</label>
                        <input type="text" class="form-control" name="@nameof(Model.ShipperName)"
                               value="@Model.ShipperName" placeholder="Nhập tên người giao hàng" autofocus />
                        @Html.ValidationMessage(nameof(Model.ShipperName), "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Điện thoại</label>
                        <input type="tel" class="form-control" name="@nameof(Model.Phone)"
                               value="@Model.Phone" placeholder="Nhập số điện thoại" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>