@model OrderDetailViewInfo
@{
    Layout = null;
}
<div class="modal-header">
    <strong class="modal-title">Cập nhật mặt hàng trong giỏ hàng</strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

@if (Model != null)
{
    <div class="modal-body">
        <form id="formEditCartItem" action="~/Order/UpdateCartItem" method="post" onsubmit="updateCartItem(event, this)">
            <input type="hidden" name="ProductID" value="@Model.ProductID" />

            <div class="row">
                <div class="col-sm-8">
                    <div class="mb-3">
                        <label class="fw-bold">Tên mặt hàng:</label>
                        <div class="form-control-plaintext">@Model.ProductName</div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold">Đơn vị tính:</label>
                        <div class="form-control-plaintext">@Model.Unit</div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold">Số lượng:</label>
                        <input type="number"
                               name="Quantity"
                               value="@Model.Quantity"
                               class="form-control"
                               min="1"
                               required
                               autofocus />
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold">Đơn giá:</label>
                        @* Thường giỏ hàng sẽ lấy giá mặc định, để readonly nếu không cho phép nhân viên sửa *@
                        <input type="text"
                               name="SalePrice"
                               value="@Model.SalePrice.ToString("N0")"
                               class="form-control number-separator"
                               readonly />
                        <small class="text-muted"><i>Giá bán cố định theo hệ thống</i></small>
                    </div>
                </div>

                <div class="col-sm-4 text-center">
                    <label class="fw-bold d-block mb-2">Ảnh minh họa</label>
                    <img src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                         class="img-thumbnail img-fluid"
                         style="max-height:150px">
                </div>
            </div>
        </form>
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-primary" form="formEditCartItem">Cập nhật</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
}
else
{
    <div class="modal-body text-danger text-center">
        Dữ liệu mặt hàng không tồn tại hoặc đã bị xóa khỏi giỏ hàng.
    </div>
}