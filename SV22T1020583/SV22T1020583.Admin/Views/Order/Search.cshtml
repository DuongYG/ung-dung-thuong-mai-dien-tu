@model PagedResult<OrderViewInfo>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> đơn hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Ngày đặt hàng</th>
                    <th>Tên khách hàng</th>
                    <th>Điện thoại</th>
                    <th>Ngày duyệt</th>
                    <th>Nhân viên xử lý</th>
                    <th class="text-end">Tổng tiền</th>
                    <th class="text-center" style="width:100px;">Trạng thái</th>
                    <th class="text-center" style="width:40px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.DataItems)
                {
                    <tr>
                        <td>@order.OrderTime</td>
                        <td>@order.CustomerName</td>
                        <td>@order.CustomerPhone</td>
                        <td>@order.AcceptTime</td>
                        <td>@order.EmployeeName</td>
                        <td class="text-end">Chưa có</td>
                        <td class="text-center">
                            @switch (order.Status)
                            {
                                case OrderStatusEnum.New:
                                    <span class="badge bg-info text-dark">Chờ xác nhận</span>
                                    break;
                                case OrderStatusEnum.Accepted:
                                    <span class="badge bg-primary">Đã duyệt</span>
                                    break;
                                case OrderStatusEnum.Shipping:
                                    <span class="badge bg-warning text-dark">Đang giao hàng</span>
                                    break;
                                case OrderStatusEnum.Completed:
                                    <span class="badge bg-success">Hoàn tất</span>
                                    break;
                                case OrderStatusEnum.Cancelled:
                                    <span class="badge bg-danger">Đã hủy</span>
                                    break;
                                case OrderStatusEnum.Rejected:
                                    <span class="badge bg-secondary">Bị từ chối</span>
                                    break;
                                default:
                                    <span class="badge bg-light text-dark">Không xác định</span>
                                    break;
                            }
                        </td>
                        <td class="text-center text-nowrap">
                            <a href="~/Order/Detail/@order.OrderID" class="btn btn-sm btn-primary">
                                <i class="bi bi-receipt"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        <ul class="pagination justify-content-center mb-0">
            @foreach (var p in Model.GetDisplayPages())
            {
                if (p.IsCurrent)
                {
                    <li class="page-item active">
                        <span class="page-link">@p.Page</span>
                    </li>

                }
                else if (p.IsEllipsis)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">
                            @p.Page
                        </a>
                    </li>
                }
            }
        </ul>
    </div>
</div>
